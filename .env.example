# wau-profile-service 环境变量模板
# v0.8.0 M2-2
#
# 复制为 .env 后填实际值(注意 .env 不入仓)
# cp .env.example .env

# ============ gRPC 服务 ============
WAU_PROFILE_GRPC_ADDR=:50062
WAU_PROFILE_VERSION=v0.8.0-M2-2

# ============ 后端选择 ============
# memory: M2-1 默认,仅 dev/test,数据不持久化
# redis:  M2-2 推荐生产,持久化 + 跨实例共享
WAU_PROFILE_BACKEND=redis

# ============ Redis 配置(per 2026-06-21 memory)============
# 43.134.126.126:6379 是公网 Redis(per 2026-06-21 部署,密码在 env)
WAU_PROFILE_REDIS_ADDR=43.134.126.126:6379
# 密码从 env 读,不 echo 完整 password(per feedback-redis-password-leak-2026-06-21)
# export WAU_PROFILE_REDIS_PASSWORD=<your_password>
WAU_PROFILE_REDIS_DB=2

# ============ Tenant 白名单 ============
# 逗号分隔,默认 ["default"]
# M2-1 兼容: "default" 始终在白名单(即使不显式列出)
WAU_PROFILE_ALLOWED_TENANTS=default,tenant-A,tenant-B

# ============ TTL ============
# 0 = 永不过期(默认)
# 30m = 30 分钟过期
# 24h = 1 天
WAU_PROFILE_TTL=0

# ============ 示例(本机开发)============
# WAU_PROFILE_BACKEND=memory
# WAU_PROFILE_GRPC_ADDR=:50062
